# =============================================================================
# Local Cyber Range — Environment Variables
# =============================================================================
# These passwords are deliberately weak — training environment only.
# Do NOT use these values in any production or real-world context.
# =============================================================================

# ── Single range password (used for all local admin / service accounts) ───────
RANGE_PASSWORD=Password!

# ── Active Directory — secure.net ─────────────────────────────────────────────
AD_DOMAIN=secure.net
AD_NETBIOS=SECURE
AD_ADMIN_PASSWORD=Password!
AD_SAFE_MODE_PASSWORD=Password!

# ── MSSQL Server (db01) ───────────────────────────────────────────────────────
ACCEPT_EULA=Y
MSSQL_SA_PASSWORD=Password!

# ── Wazuh SIEM ────────────────────────────────────────────────────────────────
WAZUH_VERSION=4.9.2
# PSK used by all agents to auto-enroll with the Wazuh manager
WAZUH_ENROLLMENT_PSK=cyberrange-psk-2024
WAZUH_API_PASSWORD=Password!
WAZUH_INDEXER_PASSWORD=Password!

# ── Setup / C2 network ────────────────────────────────────────────────────────
# Scenario container C2 IP — Windows VMs download their setup.ps1 from here
SETUP_SERVER=172.16.0.1
# Wazuh manager C2 IP — all Linux agents report to this address
WAZUH_MANAGER=172.16.0.5
