{
    # Use the range CA as Caddy's PKI root.
    # Caddy mints per-domain certs on first connection, signed by range-ca.
    # Participants install range-ca.crt once; all fake internet domains get valid TLS.
    pki {
        ca range-ca {
            root {
                cert /etc/caddy/range-ca.crt
                key  /etc/caddy/range-ca.key
            }
        }
    }

    on_demand_tls {
        ask http://localhost:9090/
    }
}

# HTTP → HTTPS redirect
:80 {
    redir https://{host}{uri} permanent
}

# HTTPS catch-all — serves any hostname; Caddy mints cert on first connection
:443 {
    tls {
        ca range-ca
        on_demand
    }

    log {
        output stdout
        format json
    }

    # Per-domain file server: /srv/www/<hostname>/ if index.html exists, else fallback
    @has_dir file /srv/www/{host}/index.html
    handle @has_dir {
        root * /srv/www/{host}
        file_server
    }
    handle {
        root * /srv/www/_default
        file_server
    }
}
