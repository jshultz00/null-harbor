FROM kalilinux/kali-rolling

# ── APT packages — single layer for cache efficiency ──────────────────────────
RUN DEBIAN_FRONTEND=noninteractive apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
    # Network recon
    nmap masscan hping3 tcpdump wireshark-common netcat-openbsd \
    # AD/Windows attacks
    impacket-scripts smbclient netexec evil-winrm \
    # Web attacks
    nikto sqlmap gobuster ffuf \
    # Credential attacks
    hashcat john hydra \
    # Post-exploitation
    metasploit-framework \
    # Email / phishing
    postfix swaks \
    # Utilities
    curl wget python3 python3-pip python3-yaml git vim tmux openssh-client jq qrencode \
    dnsutils \
    iproute2 \
  && rm -rf /var/lib/apt/lists/*

# ── Responder ──────────────────────────────────────────────────────────────────
RUN git clone --depth 1 https://github.com/lgandx/Responder.git /opt/Responder

# ── bloodhound-python ──────────────────────────────────────────────────────────
RUN pip3 install --break-system-packages bloodhound

# ── Sliver C2 ─────────────────────────────────────────────────────────────────
# Download pre-compiled binaries directly — the sliver.sh install script requires
# minisign and build-essential which are not in Kali repos.
# Pinned: v1.5.42 — update ARG and this comment when upgrading
ARG SLIVER_VERSION=v1.5.42
RUN set -eux; \
    curl -sSL "https://github.com/BishopFox/sliver/releases/download/${SLIVER_VERSION}/sliver-server_linux" \
      -o /usr/bin/sliver-server && chmod +x /usr/bin/sliver-server; \
    curl -sSL "https://github.com/BishopFox/sliver/releases/download/${SLIVER_VERSION}/sliver-client_linux" \
      -o /usr/bin/sliver && chmod +x /usr/bin/sliver

# ── Caddy — latest release binary for linux/amd64 ─────────────────────────────
RUN set -eux; \
    CADDY_URL=$(curl -s https://api.github.com/repos/caddyserver/caddy/releases/latest \
      | python3 -c "import sys,json; assets=[a['browser_download_url'] for a in \
        json.load(sys.stdin)['assets'] \
        if 'linux_amd64.tar.gz' in a['name'] and 'caddy_' in a['name']]; print(assets[0])"); \
    curl -sL "$CADDY_URL" | tar xz -C /tmp caddy; \
    mv /tmp/caddy /usr/bin/caddy; \
    chmod +x /usr/bin/caddy

# ── CoreDNS — latest release binary for linux/amd64 ──────────────────────────
RUN set -eux; \
    COREDNS_URL=$(curl -s https://api.github.com/repos/coredns/coredns/releases/latest \
      | python3 -c "import sys,json; assets=[a['browser_download_url'] for a in \
        json.load(sys.stdin)['assets'] \
        if 'linux_amd64.tgz' in a['name']]; print(assets[0])"); \
    curl -sL "$COREDNS_URL" | tar xz -C /tmp coredns; \
    mv /tmp/coredns /usr/bin/coredns; \
    chmod +x /usr/bin/coredns

# ── yq — Go binary from mikefarah/yq ─────────────────────────────────────────
RUN set -eux; \
    YQ_URL=$(curl -s https://api.github.com/repos/mikefarah/yq/releases/latest \
      | python3 -c "import sys,json; assets=[a['browser_download_url'] for a in \
        json.load(sys.stdin)['assets'] \
        if a['name'] == 'yq_linux_amd64']; print(assets[0])"); \
    curl -sL "$YQ_URL" -o /usr/bin/yq; \
    chmod +x /usr/bin/yq

# ── Saffron server binary (pre-compiled, named 'server' on disk) ──────────────
COPY server /usr/bin/saffron-server
RUN chmod +x /usr/bin/saffron-server

# ── CRS helper scripts ─────────────────────────────────────────────────────────
COPY crs/*.bash /usr/bin/
RUN chmod +x /usr/bin/*.bash

# ── Config files ───────────────────────────────────────────────────────────────
COPY entrypoint.sh /entrypoint.sh
COPY Caddyfile /etc/caddy/Caddyfile
COPY Corefile /etc/coredns/Corefile
COPY postfix-main.cf /etc/postfix/main.cf
COPY transport /etc/postfix/transport
RUN postmap /etc/postfix/transport

# ── Range CA (generated by operator before docker build — gitignored) ──────────
COPY range-ca.crt /etc/caddy/range-ca.crt
COPY range-ca.key /etc/caddy/range-ca.key

# ── Directory setup ────────────────────────────────────────────────────────────
RUN mkdir -p /srv/www /srv/setup /opt/saffron/data /etc/coredns/zones /home/attacker/scenarios
# Serve range CA cert via Python setup server for participant download
RUN cp /etc/caddy/range-ca.crt /srv/setup/range-ca.crt
# Note: DO NOT write /etc/resolv.conf here — Docker overwrites it at container start.
# entrypoint.sh writes it as the first action.
RUN chmod +x /entrypoint.sh

WORKDIR /home/attacker
ENTRYPOINT ["/entrypoint.sh"]
