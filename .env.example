# =============================================================================
# Local Cyber Range — Environment Variables (Example)
# =============================================================================
# Copy this file to .env and fill in values before running 'make build'.
# =============================================================================

RANGE_PASSWORD=<your-weak-training-password>

AD_DOMAIN=secure.net
AD_NETBIOS=SECURE
AD_ADMIN_PASSWORD=<same-as-RANGE_PASSWORD>

ACCEPT_EULA=Y
MSSQL_SA_PASSWORD=<same-as-RANGE_PASSWORD>

WAZUH_VERSION=4.9.2
WAZUH_ENROLLMENT_PSK=<random-string>
WAZUH_API_PASSWORD=<same-as-RANGE_PASSWORD>
WAZUH_INDEXER_PASSWORD=<same-as-RANGE_PASSWORD>

SETUP_SERVER=172.16.0.1
WAZUH_MANAGER=172.16.0.5
